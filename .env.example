# Environment Variables — SaveTheMommy MediCare
# Copy this file to .env for local development (never commit .env)

# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your-very-secret-key-change-this

# ── Firebase ──────────────────────────────────────────────────────────────────
# Paste the ENTIRE contents of firebase_key.json as a single-line JSON string.
# In bash: export FIREBASE_KEY_JSON=$(cat firebase_key.json | tr -d '\n')
FIREBASE_KEY_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# ── SQLite path ────────────────────────────────────────────────────────────────
# Local:   leave as db_local.sqlite
# Railway: Add a Volume in Railway dashboard (mount at /data),
#          then set SQLITE_PATH=/data/db_local.sqlite
SQLITE_PATH=db_local.sqlite

# ── Railway ────────────────────────────────────────────────────────────────────
# Set automatically by Railway. Controls server-side logging behaviour.
RAILWAY_ENVIRONMENT=production
